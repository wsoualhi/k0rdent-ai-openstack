# OpenStack Credentials
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

export OS_AUTH_URL=https://your-keystone-url/
export OS_PROJECT_ID=your-project-id
export OS_PROJECT_NAME="your-project-name"
export OS_USER_DOMAIN_NAME="Default"
export OS_PROJECT_DOMAIN_ID="default"
export OS_USERNAME="your-username"
export OS_PASSWORD="your-password"
export OS_REGION_NAME="RegionOne"
export OS_INTERFACE=public
export OS_IDENTITY_API_VERSION=3

# Terraform variables (TF_VAR_ prefix is auto-consumed by Terraform).
# These are the single source of truth — keep the matching settings in
# terraform.tfvars commented out so these values are not overridden
# (terraform.tfvars takes precedence over TF_VAR_ environment variables).
export TF_VAR_openstack_auth_url=https://your-keystone-url/
export TF_VAR_openstack_region=RegionOne
export TF_VAR_external_address=

# OIDC configuration (set TF_VAR_oidc_enabled=true to enable)
export TF_VAR_oidc_enabled=false
export TF_VAR_oidc_issuer_url=https://accounts.google.com
export TF_VAR_oidc_client_id=your-oidc-client-id.apps.googleusercontent.com
export TF_VAR_oidc_client_secret_id=your-oidc-client-secret

# =============================================================================
# Phase 2 — k0rdent Enterprise (management + child clusters + MSR)
# Single source of truth for all Phase-2 manifests. Manifests are committed with
# ${VAR} placeholders and rendered at apply time with:  envsubst < file | kubectl apply -f -
# Change values here ONLY — never edit the manifests.
# =============================================================================

# --- k0rdent Enterprise (KCM) ---
export KCM_VERSION="1.4.0"
export MIRANTIS_REGISTRY_USER="your-mirantis-user"
export MIRANTIS_REGISTRY_TOKEN="your-mirantis-token"

# --- Child cluster (ClusterDeployment on OpenStack) ---
export CHILD_CLUSTER_NAME="child-1"
export OPENSTACK_CLUSTER_TEMPLATE="openstack-standalone-cp-1-0-37"   # confirm: kubectl get clustertemplate -n kcm-system
export CHILD_IMAGE_NAME="ubuntu-22.04"
export OPENSTACK_EXTERNAL_NETWORK="public"
export CHILD_CP_FLAVOR="m1.medium"     # control plane (etcd+API) — a smaller flavor is enough
export CHILD_CP_COUNT="3"              # 3 = HA etcd quorum (use 1 for a lean PoC)
export CHILD_WORKER_FLAVOR="m1.large"  # workers run the tooling workloads
export CHILD_WORKER_COUNT="2"
# Node disk comes from the FLAVOR (no rootVolumeSize in the template's schema).
# (child cluster reuses OS_REGION_NAME above for the OpenStack region)

# --- MSR service stack ---
export MSR_FQDN="msr.registry.example.com"
export MSR_NAMESPACE="msr"
export MSR_SERVICE_NAME="msr"          # confirm from the MSR helm chart
export MSR_SERVICE_PORT="443"          # confirm from the MSR helm chart
export TRAEFIK_CHART_VERSION="34.1.0"  # confirm desired Traefik chart version
export MSR_CHART_VERSION="your-msr-chart-version"

# --- TLS CSR subject (for the MSR public certificate signed by your CA) ---
export CSR_ORG="Example Org"
export CSR_OU="IT"
export CSR_CITY="City"
export CSR_STATE="State"
export CSR_COUNTRY="DE"
